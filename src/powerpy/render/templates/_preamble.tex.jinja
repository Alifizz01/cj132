% =====================================================================
% Shared AIRBUS-house-style preamble, included by both the electrical
% (report.tex.jinja) and thermal (thermal_report.tex.jinja) masters.
% Requires the context to provide ``document`` (for the running header).
% =====================================================================
\documentclass[11pt, a4paper]{article}

\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{lmodern}            % crisp Computer-Modern-compatible serif
\usepackage{microtype}
\usepackage[a4paper, margin=25mm, headheight=26pt, headsep=14pt]{geometry}
\usepackage{graphicx}
\usepackage{booktabs}
\usepackage{longtable}
\usepackage{array}
\usepackage{tabularx}
\usepackage{xltabular}   % page-breaking, width-constrained longtable
\usepackage{siunitx}
\usepackage[table]{xcolor}
\usepackage{colortbl}
\usepackage{fancyhdr}
\usepackage{caption}
\usepackage{float}
\usepackage{amsmath}
\usepackage[hidelinks]{hyperref}

% --- AIRBUS house colours / wordmark --------------------------------
% No bitmap logo is shipped; the wordmark is set in a bold sans face so
% the report never depends on a missing asset.
\definecolor{airbusblue}{HTML}{00205B}
\definecolor{rulegrey}{HTML}{9A9A9A}
% report-table palette: shaded header + zebra body + soft grid.
\definecolor{tableheadgrey}{HTML}{D9D9D9}
\definecolor{tablerowgrey}{HTML}{F2F2F2}
\definecolor{tablegridgrey}{HTML}{8C8C8C}
\newcommand{\airbusmark}[1][\Large]{%
  {\fontfamily{phv}\selectfont\bfseries\color{airbusblue}#1 AIRBUS}}

\sisetup{detect-all = true, group-separator = {\,}, output-decimal-marker={.}}

\captionsetup{font=small, labelfont=bf, labelsep=colon,
              skip=6pt, justification=centering}

\renewcommand{\arraystretch}{1.3}
\arrayrulecolor{tablegridgrey}
\setlength{\arrayrulewidth}{0.4pt}
% A header row used by every report table: grey fill, bold labels.
\newcommand{\reporthead}[1]{\rowcolor{tableheadgrey}#1}
% Left-aligned stretchy column so every table fills \linewidth -> all the
% report tables render at the same (full text) width.
\newcolumntype{L}{>{\raggedright\arraybackslash}X}

% --- running header / footer ----------------------------------------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\footnotesize\color{rulegrey}%
              << document.doc_number | tex >>}
\fancyhead[R]{\airbusmark[\normalsize]}
\fancyfoot[C]{\footnotesize\thepage}
\renewcommand{\headrulewidth}{0.6pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{rulegrey}%
              \leaders\hrule height \headrulewidth\hfill}}

% Plain pages (title, ToC first page) keep a clean look.
\fancypagestyle{plain}{%
  \fancyhf{}\renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\footnotesize\thepage}}
